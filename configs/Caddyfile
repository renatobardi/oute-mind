# Caddy - Acesso via IP (sem domínio)
:80 {
	encode gzip

	# Security headers
	header X-Frame-Options DENY
	header X-Content-Type-Options nosniff
	header X-XSS-Protection "1; mode=block"
	header Referrer-Policy no-referrer

	# oute-main Dashboard (path-stripped: /dashboard/x → /x)
	handle_path /dashboard/* {
		reverse_proxy http://00_dashboard:3000
	}
	handle_path /dashboard {
		reverse_proxy http://00_dashboard:3000
	}

	# oute-main Auth API (no strip: /api/auth/* matches SvelteKit routes)
	handle /api/auth/* {
		reverse_proxy http://01_auth-profile:3001
	}
	handle /api/auth {
		reverse_proxy http://01_auth-profile:3001
	}

	# oute-main Projects API (no strip: SvelteKit routes start with /api/projects)
	handle /api/projects/* {
		reverse_proxy http://02_projects:3002
	}
	handle /api/projects {
		reverse_proxy http://02_projects:3002
	}

	# Landing page (99_home) - root path
	handle / {
		reverse_proxy http://99_home:3003
	}

	# Chat interface (03_interview)
	handle /chat* {
		reverse_proxy http://03_interview:3002
	}

	# Health check (responds directly, no proxy)
	handle /caddy-health {
		respond "OK" 200
	}

	# FastAPI (oute-mind catch-all)
	handle {
		reverse_proxy http://app:8000
	}
}
