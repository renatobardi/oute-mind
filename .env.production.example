# ===== GCP DEPLOYMENT =====
GCP_PROJECT_ID=oute-mind
GCP_VM_HOSTNAME=<obtém após criar a VM - IP estático>
GCP_VM_USER=ubuntu
GCP_VM_SSH_PRIVATE_KEY=<sua chave SSH privada em base64>
GCP_VM_SSH_KNOWN_HOSTS=<será gerado ao SSH pela primeira vez>

# ===== API KEYS (aplicação) =====
GOOGLE_API_KEY=<mesmo valor do Oracle Cloud, se tiver>
SERPER_API_KEY=<seu Serper API key>
COMPOSIO_API_KEY=<seu Composio API key>
OCR_API_KEY=<seu OCR API key>

# ===== DATABASE CREDENTIALS =====
POSTGRES_USER=oute_prod_user
POSTGRES_PASSWORD=<gere com: openssl rand -base64 32>
POSTGRES_DB=oute_production

# ===== REDIS CREDENTIALS =====
REDIS_PASSWORD=<gere com: openssl rand -base64 32>

# ===== QDRANT CREDENTIALS =====
QDRANT_API_KEY=<gere com: openssl rand -hex 16>
QDRANT_MASTER_KEY=<gere com: openssl rand -hex 16>

# ===== MINDSDB CREDENTIALS =====
MINDSDB_ADMIN_PASSWORD=<gere com: openssl rand -base64 32>

# ===== FASTAPI =====
FASTAPI_PORT=8000
FASTAPI_WORKERS=4

# ===== GRAFANA =====
GRAFANA_PASSWORD=<gere com: openssl rand -base64 32>
